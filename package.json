{
  "name": "tcode",
  "version": "1.0.0",
  "description": "Run multiple Claude Code agents simultaneously in a unified dashboard",
  "type": "module",
  "scripts": {
    "dev": "node build-server.mjs && tauri dev",
    "build": "node build-server.mjs && tauri build",
    "vite:dev": "vite",
    "vite:build": "vite build",
    "server:build": "node build-server.mjs",
    "server:dev": "tsx server/index.ts",
    "dev:services": "concurrently \"npm run server:dev\" \"npm run vite:dev\""
  },
  "dependencies": {
    "@tauri-apps/api": "^2.5.0",
    "@tauri-apps/plugin-dialog": "^2.2.0",
    "@tauri-apps/plugin-shell": "^2.2.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "better-sqlite3": "^12.8.0",
    "express": "^5.2.1",
    "node-pty": "^1.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ws": "^8.20.0",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.5.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.19",
    "concurrently": "^9.2.1",
    "esbuild": "^0.28.0",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "tsx": "^4.21.0",
    "typescript": "^5.4.5",
    "vite": "^5.3.1"
  }
}
